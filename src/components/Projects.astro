---
interface Props {
    projects: Projects[];
}

const { projects } = Astro.props;
---

<div class="grid lg:grid-cols-5 md:grid-cols-3 sm:grid-cols-2 gap-4">
    {
        projects.map((project, index) => (
            <a
                href={project.link ? project.link : null}
                class="select-none bg-white border-2 transition-all  rounded-lg p-4 shadow-[0_0_0_2px_rgba(0,0,0,1)] hover:shadow-[0_0_0_4px_rgba(0,0,0,1)] hover:border-blue-500 hover:shadow-blue-500 active:shadow-[0_0_0_2px_rgba(0,0,0,1)]"
            >
                <h3 class="font-general-sans text-lg font-bold">
                    {project.title}
                </h3>
                <p class="font-general-sans text-sm">{project.description}</p>
            </a>
        ))
    }
</div>
