---
import { Image } from 'astro:assets';

interface Props {
    caption: string;
    src: string;
    width: number;
    height: number;
}

const props = Astro.props;
---

<div class="image-container">
    <Image width={props.width} height={props.height} src={props.src} alt={props.caption} />
    <p>{props.caption}</p>
</div>

<style>
    .image-container {
        width: 100%;
        
        display: flex;
        flex-direction: column;
        gap: 1rem;

        padding: .5rem;
        
        p {
            text-align: center;
            color: var(--comment-fg);
        }
    }
</style>