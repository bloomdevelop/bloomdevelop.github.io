<script>
  import { animate, spring } from "motion";

  // Store active notifications by unique id
  const notifications = new Map();
  let notificationCounter = 0;

  function showController(index, type = "connected") {
    const stack = document.getElementById("controller-stack");
    if (!stack) return;
    // Create notification element
    const container = document.createElement("div");
    container.className =
      "controller-container bg-accent-900 text-text-900 dark:text-text-50 px-5 py-4 flex flex-row justify-center items-center gap-4 rounded-full shadow-lg";
    container.style.opacity = "0";
    container.style.transform = "translateX(500px)";
    // Unique notification id
    const notificationId = `controller-${index}-${type}-${notificationCounter++}`;
    container.dataset.notificationId = notificationId;
    const message = type === "connected"
      ? `Controller <span class=\"controller-index\">${index + 1}</span> connected`
      : `Controller <span class=\"controller-index\">${index + 1}</span> disconnected`;
    // Use Astro Icon as inline SVG
    const iconColor = type === "disconnected" ? 'filter: grayscale(1) opacity(0.5);' : '';
    container.innerHTML = `
      <span style="display: flex; align-items: center; ${iconColor}">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M4.725 20q-1.5 0-2.562-1.075t-1.113-2.6q0-.225.025-.45t.075-.45l2.1-8.4q.35-1.35 1.425-2.187T7.125 4h9.75q1.375 0 2.45.838t1.425 2.187l2.1 8.4q.05.225.088.463t.037.462q0 1.525-1.088 2.588T19.276 20q-1.05 0-1.95-.55t-1.35-1.5l-.7-1.45q-.125-.25-.375-.375T14.375 16h-4.75q-.275 0-.525.125t-.375.375l-.7 1.45q-.45.95-1.35 1.5t-1.95.55m.075-2q.475 0 .863-.25t.587-.675l.7-1.425q.375-.775 1.1-1.213T9.625 14h4.75q.85 0 1.575.45t1.125 1.2l.7 1.425q.2.425.588.675t.862.25q.7 0 1.2-.462t.525-1.163q0 .025-.05-.475l-2.1-8.375q-.175-.675-.7-1.1T16.875 6h-9.75q-.7 0-1.237.425t-.688 1.1L3.1 15.9q-.05.15-.05.45q0 .7.513 1.175T4.8 18m8.7-7q.425 0 .713-.287T14.5 10t-.288-.712T13.5 9t-.712.288T12.5 10t.288.713t.712.287m2-2q.425 0 .713-.288T16.5 8t-.288-.712T15.5 7t-.712.288T14.5 8t.288.713T15.5 9m0 4q.425 0 .713-.288T16.5 12t-.288-.712T15.5 11t-.712.288T14.5 12t.288.713t.712.287m2-2q.425 0 .713-.288T18.5 10t-.288-.712T17.5 9t-.712.288T16.5 10t.288.713t.712.287m-9 1.5q.325 0 .538-.213t.212-.537v-1h1q.325 0 .538-.213T11 10t-.213-.537t-.537-.213h-1v-1q0-.325-.213-.537T8.5 7.5t-.537.213t-.213.537v1h-1q-.325 0-.537.213T6 10t.213.538t.537.212h1v1q0 .325.213.538t.537.212M12 12"/></svg>
      </span>
      <span class="text-xl">${message}</span>
    `;
    // Add to stack
    stack.appendChild(container);
    notifications.set(notificationId, container);
    // Animate in (bouncy)
    animate(
      container,
      { opacity: [0, 1], scale: [0.7, 1], transform: ["translateX(500px)", "translateX(0px)"] },
      { type: spring, bounce: 0.45, duration: 0.7 }
    ).then(() => {
      setTimeout(() => {
        hideControllerById(notificationId);
      }, 5000);
    });
  }

  function hideControllerById(notificationId) {
    const container = notifications.get(notificationId);
    if (!container) return;
    animate(
      container,
      { opacity: [1, 0], scale: [1, 0.7], transform: ["translateX(0px)", "translateX(500px)"] },
      { type: spring, bounce: 0.2 }
    ).then(() => {
      container.remove();
      notifications.delete(notificationId);
    });
  }

  window.addEventListener("gamepadconnected", (ev) => {
    const gamepad = ev.gamepad;
    showController(gamepad.index, "connected");
  });

  window.addEventListener("gamepaddisconnected", (ev) => {
    const gamepad = ev.gamepad;
    showController(gamepad.index, "disconnected");
  });

  window.addEventListener("DOMContentLoaded", () => {
    const stack = document.getElementById("controller-stack");
    if (stack) stack.innerHTML = "";
    notifications.clear();
  });
</script>
<div
  id="controller-stack"
  style="position: fixed; top: 1.25rem; right: 1.25rem; display: flex; flex-direction: column; gap: 1rem; z-index: 50; align-items: flex-end; pointer-events: none;"
>
</div>
