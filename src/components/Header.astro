---
import { SITE_NAME } from "../const";
import HeaderLink from "./HeaderLink.astro";
---

<nav>
    <h1>{SITE_NAME}</h1>
    <div>
        <HeaderLink href="/">Home</HeaderLink>
        <HeaderLink href="/posts">Posts</HeaderLink>
    </div>
</nav>

<style>
    nav {
        z-index: 9999;
        display: flex;
        flex-direction: row;
        align-items: flex-end;
        gap: 2rem;
        padding: 0.5rem 1rem;
        margin: 0;
        border-bottom: solid 2px var(--border);
    }

    h1 {
        padding: 0;
        line-height: 1em;
        margin: 0;
    }

    nav > div {
        display: flex;
        flex-direction: row;
        gap: 1rem;
    }
</style>
