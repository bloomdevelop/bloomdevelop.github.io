---
import Footer from "@/components/astro/Footer.astro";
import Toolbar from "@/components/react/Toolbar";
import "../styles/global.css";
import Controller from "@/components/astro/controller/Controller.astro";
import CursorController from "@/components/astro/controller/CursorController.astro";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>My Site :3</title>
    </head>
    <body class="bg-background-50 dark:bg-background-950">
        <CursorController />
        <Controller />
        <Toolbar client:only/>
        <slot />
        <Footer />
    </body>
</html>
