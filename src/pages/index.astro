---
import Links from "../components/Links.astro";
import MyName from "../components/MyName.astro";
import Projects from "../components/Projects.astro";
import Section from "../components/Section.astro";
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import pfp from "../assets/pfp.png";
import { getYearsBetweenDates } from "../utils";

const links: Links[] = [
    {
        title: "GitHub",
        url: "https://github.com/bloomdevelop",
    },
    {
        title: "Bluesky",
        url: "https://bsky.app/profile/spring.furrest.online",
    },
    {
        title: "Revolt",
        clipboard: "spring#5321",
    },
    {
        title: "Discord",
        clipboard: "spring.gay",
    },
];

const projects: Projects[] = [
    {
        title: "Github Search",
        description:
            "Made with Solid and Solid Start less than 3 hours. Uses Github API for searching.",
    },
    {
        title: "Silk",
        description: "Multi Purpose Revolt Bot",
    },
    {
        title: "Tasks",
        description:
            "Todo app made with Solid and other headless component libaries",
    },
    {
        title: "Anti Mass-Ping",
        description: "A Revolt bot that prevents peoples from mass pinging",
    },
    {
        title: "ReChat",
        description:
            "Revolt third party client, created with Solid and SUID (Solid Material), it's very broken (even worse, discontinued)",
    },
];

const startDate = new Date("2008-04-17");
const endDate = new Date(Date.now());
---

<script>
    import { scroll } from "motion";

    scroll((progress: number) => console.log(progress));
</script>
<Layout>
    <MyName name="Bloom Perez" />
    <Section title="Links & Socials">
        <Links links={links} client:only />
    </Section>
    <Section title="About Myself">
        <div class="flex flex-col md:flex-row gap-4">
            <div class="justify-center items-center flex flex-col gap-4">
                <Image
                    class="rounded-lg border-2 shadow-[2px_2px_0_2px_rgba(0,0,0,1)] w-full max-w-xs"
                    src={pfp}
                    alt="Profile Picture"
                />
                <p class="font-general-sans">
                    Art by <a
                        class="text-blue-500 hover:underline"
                        href="https://bsky.app/profile/winteriris42.bsky.social"
                        target="_blank"
                        rel="noopener noreferrer">WinterIris42 on Bluesky</a
                    >
                </p>
            </div>
            <div class="flex flex-col gap-2">
                <p class="font-general-sans">
                    {getYearsBetweenDates(startDate, endDate)} years old, yet a furry
                    programmer (I'm still a student), currently on last year of high
                    school. I'm currently learning web development with Astro, Solid,
                    React and Tailwind CSS, also a web designer. Also I'm learning
                    mobile development with Kotlin and Compose, thanks to on the
                    recent contribution from Crescent repository on Github.
                </p>
                <div class="flex flex-col gap-4">
                    <h3 class="font-semibold text-2xl">My Contributions</h3>
                    <a
                        href={"https://github.com/upryzing/crescent"}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="select-none bg-white border-2 transition-all rounded-lg p-4 shadow-[0_0_0_2px_rgba(0,0,0,1)] hover:shadow-[0_0_0_4px_rgba(0,0,0,1)] hover:border-blue-500 hover:shadow-blue-500 active:shadow-[0_0_0_2px_rgba(0,0,0,1)]"
                    >
                        <div
                            class="flex lg:flex-row md:flex-col sm:flex-col xs:flex-col gap-2"
                        >
                            <h3 class="font-general-sans text-lg font-bold">
                                Crescent
                            </h3>
                            <div
                                class="flex flex-row items-center flex-wrap gap-2"
                            >
                                <div
                                    class="px-1 py-0.5 border rounded-full text-xs bg-blue-300"
                                >
                                    Designed the entirely of the application
                                    with 80+ Commits
                                </div>
                                <div
                                    class="px-1 py-0.5 border rounded-full text-xs bg-green-300"
                                >
                                    ++ 3,481
                                </div>
                                <div
                                    class="px-1 py-0.5 border rounded-full text-xs bg-red-300"
                                >
                                    -- 1,268
                                </div>
                            </div>
                        </div>
                        <p class="font-general-sans text-sm">
                            DM-focused mobile app for Upryzing, built with
                            Kotlin and Jetpack Compose
                        </p>
                    </a>
                    <a
                        href={"https://codeberg.org/amycatgirl/revoltmini"}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="select-none bg-white border-2 transition-all rounded-lg p-4 shadow-[0_0_0_2px_rgba(0,0,0,1)] hover:shadow-[0_0_0_4px_rgba(0,0,0,1)] hover:border-blue-500 hover:shadow-blue-500 active:shadow-[0_0_0_2px_rgba(0,0,0,1)]"
                    >
                        <div
                            class="flex lg:flex-row md:flex-col sm:flex-col xs:flex-col gap-2"
                        >
                            <h3 class="font-general-sans text-lg font-bold">
                                RevoltMini
                            </h3>
                            <div
                                class="flex flex-row items-center flex-wrap gap-2"
                            >
                                <div
                                    class="px-1 py-0.5 border rounded-full text-xs bg-blue-300"
                                >
                                    Designed most part of the UI within 20
                                    commits
                                </div>
                            </div>
                        </div>
                        <p class="font-general-sans text-sm">
                            Mini version of Revolt, built with just HTML, CSS
                            and JavaScript
                        </p>
                    </a>
                </div>
            </div>
        </div>
    </Section>
    <Section title="My Projects">
        <Projects projects={projects} />
    </Section>
</Layout>
